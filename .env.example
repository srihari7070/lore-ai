# Your Anthropic API key. Lore Map brings your own key — nothing is sent anywhere
# except directly to the Anthropic API from your local machine.
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the Claude model Lore Map uses (defaults to claude-opus-4-8).
# LORE_MODEL=claude-opus-4-8

# Optional: override the local port (defaults to 3333).
# LORE_PORT=3333
